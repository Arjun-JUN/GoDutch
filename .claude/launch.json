{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Frontend (React)",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "start-frontend.js"
      ],
      "port": 3000,
      "env": {
        "BROWSER": "none"
      }
    },
    {
      "name": "Backend (FastAPI)",
      "runtimeExecutable": "python",
      "runtimeArgs": [
        "-m", "uvicorn", "server:app", "--reload", "--port", "8000"
      ],
      "cwd": "backend",
      "port": 8000
    }
  ]
}